# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
LOG_LEVEL=debug

# ─── Client ───────────────────────────────────────────────────────────────────
CLIENT_URL=http://localhost:5173

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=7d

# ─── Database (PostgreSQL / Supabase) ────────────────────────────────────────
# DATABASE_URL  → pooled connection (pgBouncer) used at runtime by Prisma Client
# DIRECT_URL    → non-pooled "Direct connection" from Supabase Dashboard
#                 (Project Settings → Database → Connection string → URI)
#                 Required by `prisma migrate dev` (shadow DB needs a real session)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:6543/DATABASE?pgbouncer=true
DIRECT_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE

# ─── Currency API (optional) ─────────────────────────────────────────────────
CURRENCY_API_KEY=your_currency_api_key_here
CURRENCY_API_URL=https://api.exchangerate.host
