// ─── Prisma Configuration ─────────────────────────────────────────────────────
// NOTE: Prisma 7+ requires the database connection URL to be configured in
// prisma.config.ts (not in this file). See prisma.config.ts in the Server root.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum SplitType {
  EQUAL
  EXACT
  PERCENTAGE
  RATIO
}

enum Currency {
  INR
  USD
  EUR
  GBP
}

enum ImportStatus {
  IMPORTED
  SKIPPED
  ERRORED
  IMPORTED_AS_SETTLEMENT
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String   @db.VarChar(100)
  email        String   @unique @db.VarChar(255)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  isGuest      Boolean  @default(false) @map("is_guest")
  createdAt    DateTime @default(now()) @map("created_at")

  // Relations
  createdGroups   Group[]           @relation("GroupCreator")
  memberships     GroupMembership[]
  paidExpenses    Expense[]         @relation("ExpensePaidBy")
  expenseSplits   ExpenseSplit[]
  settlementsPaid Settlement[]      @relation("SettlementPayer")
  settlementsReceived Settlement[]  @relation("SettlementPayee")

  @@map("users")
}

model Group {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String   @db.VarChar(100)
  createdById String   @map("created_by") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  createdBy   User              @relation("GroupCreator", fields: [createdById], references: [id])
  memberships GroupMembership[]
  expenses    Expense[]
  settlements Settlement[]
  importLogs  ImportLog[]

  @@map("groups")
}

model GroupMembership {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  groupId   String    @map("group_id") @db.Uuid
  joinedAt  DateTime  @map("joined_at") @db.Date
  leftAt    DateTime? @map("left_at") @db.Date
  createdAt DateTime  @default(now()) @map("created_at")

  // Relations
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  // Partial unique index: only one active membership per (user, group).
  // Enforced via a raw SQL partial index in migration; Prisma cannot express
  // WHERE-clause partial indexes natively, so we use @@index below for the
  // non-partial composite and rely on the SQL migration for the partial one.
  @@index([userId, groupId])
  @@map("group_memberships")
}

model Expense {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  groupId         String    @map("group_id") @db.Uuid
  description     String    @db.VarChar(255)
  amount          Decimal   @db.Decimal(12, 2)
  currency        Currency  @default(INR)
  exchangeRate    Decimal   @default(1.0) @map("exchange_rate") @db.Decimal(10, 4)
  amountInr       Decimal   @map("amount_inr") @db.Decimal(12, 2)
  paidById        String    @map("paid_by_id") @db.Uuid
  date            DateTime  @db.Date
  splitType       SplitType @map("split_type")
  isRefund        Boolean   @default(false) @map("is_refund")
  isSettlement    Boolean   @default(false) @map("is_settlement")
  notes           String?   @db.Text
  importedRowHash String?   @map("imported_row_hash") @db.VarChar(64)
  createdAt       DateTime  @default(now()) @map("created_at")

  // Relations
  group  Group          @relation(fields: [groupId], references: [id], onDelete: Cascade)
  paidBy User           @relation("ExpensePaidBy", fields: [paidById], references: [id])
  splits ExpenseSplit[]

  // Standard indexes
  @@index([groupId])
  @@index([date])
  // Partial unique index for duplicate import prevention is enforced in SQL migration.
  // Prisma does not support WHERE-clause partial indexes natively.
  @@map("expenses")
}

model ExpenseSplit {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  expenseId   String  @map("expense_id") @db.Uuid
  userId      String  @map("user_id") @db.Uuid
  amountOwed  Decimal @map("amount_owed") @db.Decimal(12, 2)

  // Relations
  expense Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@index([expenseId])
  @@index([userId])
  @@map("expense_splits")
}

model Settlement {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  groupId   String   @map("group_id") @db.Uuid
  payerId   String   @map("payer_id") @db.Uuid
  payeeId   String   @map("payee_id") @db.Uuid
  amount    Decimal  @db.Decimal(12, 2)
  date      DateTime @db.Date
  notes     String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  payer User  @relation("SettlementPayer", fields: [payerId], references: [id])
  payee User  @relation("SettlementPayee", fields: [payeeId], references: [id])

  @@map("settlements")
}

model ImportLog {
  id          String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  groupId     String?      @map("group_id") @db.Uuid
  sessionId   String       @map("session_id") @db.Uuid
  rowNumber   Int?         @map("row_number")
  rawData     String?      @map("raw_data") @db.Text
  anomalyType String?      @map("anomaly_type") @db.VarChar(50)
  actionTaken String?      @map("action_taken") @db.VarChar(50)
  status      ImportStatus
  createdAt   DateTime     @default(now()) @map("created_at")

  group Group? @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@map("import_logs")
}
